{
  "name": "immivault",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "concurrently \"pnpm --filter api dev\" \"pnpm --filter web dev\"",
    "build": "pnpm --filter shared build && pnpm --filter api build && pnpm --filter web build",
    "bootstrap": "pnpm --filter api run bootstrap",
    "seed": "pnpm --filter api run seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "@prisma/engines",
      "prisma"
    ]
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
