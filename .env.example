# Pinata
PINATA_JWT=
PINATA_GATEWAY=your-gateway.mypinata.cloud

# Anthropic
ANTHROPIC_API_KEY=

# x402 / Base
FALLBACK_WALLET=

# Contract deployment (packages/contracts)
DEPLOYER_PRIVATE_KEY=
# Set after running: pnpm --filter @immivault/contracts deploy:base-sepolia
REGISTRY_ADDRESS=
ESCROW_ADDRESS=
USDC_ADDRESS=

# Backend
PORT=3001

# Set after running: pnpm bootstrap
# Format: {"asylum-refugee":"<id>","green-card-family":"<id>",...}
PINATA_GROUPS={}

# Frontend (copy to apps/web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
